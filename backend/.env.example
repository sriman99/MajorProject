# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017

# JWT Authentication
SECRET_KEY=your-secret-key-here-change-in-production

# Email Configuration
# Choose email provider: "smtp" or "sendgrid"
EMAIL_PROVIDER=smtp

# Email sender information
FROM_EMAIL=noreply@healthcare.com
FROM_NAME=Healthcare System

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# ==========================================
# SMTP Configuration (for Gmail, Outlook, etc.)
# ==========================================
# For Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASSWORD=your-app-specific-password
#
# For Outlook:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#   SMTP_USER=your-email@outlook.com
#   SMTP_PASSWORD=your-password
#
# For Mailtrap (testing):
#   SMTP_HOST=smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_USE_TLS=true
#   SMTP_USER=your-mailtrap-username
#   SMTP_PASSWORD=your-mailtrap-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==========================================
# SendGrid Configuration (Alternative)
# ==========================================
# If using SendGrid instead of SMTP:
# 1. Set EMAIL_PROVIDER=sendgrid
# 2. Get API key from https://sendgrid.com/
# SENDGRID_API_KEY=your-sendgrid-api-key-here

# ==========================================
# Important Notes:
# ==========================================
# - For Gmail: Use App Password (not regular password)
#   Generate at: https://myaccount.google.com/apppasswords
# - Email sending is optional - system works without it
# - Leave SMTP_USER and SMTP_PASSWORD empty to disable emails
# - Emails will be logged to console if not configured
